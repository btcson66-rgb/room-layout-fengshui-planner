---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';
import Faq from '../components/Faq.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import { categoryMeta, formatDate, siteUrl } from '../data/site';

const posts = (await getCollection('blog')).sort((a, b) => b.data.updated.valueOf() - a.data.updated.valueOf());
const latestPosts = posts.slice(0, 5);
const popularPosts = posts.filter((post) => ['feng-shui', 'room-planning', 'small-room'].includes(post.data.category)).slice(0, 6);
const title = 'RoomFeng｜免費房間規劃與風水佈局工具';
const description = '輸入房間尺寸、門窗位置與家具需求，快速取得臥室、小房間、小套房與書桌配置建議，並參考床位、鏡子、採光、收納與動線風水提醒。';
const canonical = '/';
const alternates = { zh: '/', en: '/en/' };
const faq = [
  { q: '房間規劃工具可以做什麼？', a: '可以協助你整理房間尺寸、門窗位置、家具需求、動線、採光、收納與風水參考，適合搬家、租屋與買家具前使用。' },
  { q: '風水建議是保證有效嗎？', a: '不是。本站風水內容只作為傳統文化與室內配置參考，不保證任何財運、感情、健康或人生結果。' },
  { q: '小房間也能使用嗎？', a: '可以。小房間與小套房更需要先確認床、桌、衣櫃與主要走道，避免家具放得下卻不好用。' },
  { q: '租屋不能裝潢也可以改善嗎？', a: '可以。可先用家具位置、布簾、床頭板、矮櫃、收納盒與燈光做可復原調整。' },
  { q: '需要註冊才能使用嗎？', a: '不需要。本站以靜態網站與瀏覽器端工具為主，不需要資料庫或帳號。' },
];
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'RoomFeng',
    url: `${siteUrl}/`,
    inLanguage: 'zh-TW',
    description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'RoomFeng',
    url: siteUrl,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首頁', item: `${siteUrl}/` },
    ],
  },
];
const tools = [
  { href: '/zh/room-layout-planner/', title: '房間規劃工具', text: '輸入房間尺寸、門窗與家具需求，取得配置、動線、採光與收納提醒。' },
  { href: '/zh/bed-desk-wardrobe-layout/', title: '臥室配置工具', text: '檢查床、門、窗、衣櫃與書桌的配置順序與睡眠舒適度。' },
  { href: '/zh/small-bedroom-layout/', title: '小房間配置工具', text: '針對小房間、小套房與租屋情境整理收納和多功能家具建議。' },
  { href: '/zh/feng-shui-bedroom-checker/', title: '臥室風水檢查工具', text: '用 checklist 參考床對門、鏡子對床、床頭靠窗與動線問題。' },
  { href: '/zh/desk-placement-feng-shui/', title: '書桌擺放參考', text: '檢查自然光、插座、椅子後方空間與書桌風水參考。' },
];
const audiences = ['租屋族', '學生', '小房間使用者', '搬家前規劃', '想改善床位與收納的人', '想參考房間風水的人'];
const problems = ['床不知道怎麼擺', '小房間太擠', '書桌採光不好', '衣櫃擋住動線', '鏡子對床', '床對門', '房間收納混亂'];
const fengShuiQuestions = [
  { href: '/zh/blog/bed-facing-door-feng-shui/', title: '床對門怎麼辦' },
  { href: '/zh/blog/mirror-facing-bed-bedroom/', title: '鏡子對床怎麼辦' },
  { href: '/zh/blog/bed-under-window-solutions/', title: '床頭靠窗可以嗎' },
  { href: '/zh/blog/desk-facing-door-layout/', title: '書桌要怎麼擺' },
  { href: '/zh/blog/bed-head-against-wall/', title: '床頭要不要靠牆' },
];
---

<Layout title={title} description={description} canonical={canonical} lang="zh" alternates={alternates} jsonLd={jsonLd}>
  <section class="section">
    <div class="container page-grid">
      <header class="card">
        <h1>免費房間家具配置規劃工具</h1>
        <p class="lead">輸入房間尺寸、拖曳家具放入平面圖、確認動線與門口，再匯出 PNG 或 PDF。適合租屋族、搬家族、買家具前想確認尺寸的一般人。</p>
        <ol class="how-it-works">
          <li><strong>① 設定房間</strong> — 輸入長、寬、選單位</li>
          <li><strong>② 拖曳家具</strong> — 放床、桌、衣櫃、門窗等，可旋轉、調整尺寸</li>
          <li><strong>③ 匯出 / 取得建議</strong> — 存 PNG/PDF，或參考風水格局與規劃建議</li>
        </ol>
        <div class="cta-row">
          <a class="button" href="/zh/room-layout-planner/">開始畫房間平面圖</a>
          <a class="button secondary" href="/zh/feng-shui-bedroom-checker/">檢查風水格局參考</a>
        </div>
      </header>

      <section class="card" aria-labelledby="tools-heading">
        <h2 id="tools-heading">工具入口</h2>
        <div class="tool-primary">
          <article class="tool-card-main">
            <h3><a href="/zh/room-layout-planner/">🗂 拖拉式房間平面圖工具</a></h3>
            <p>輸入房間尺寸，拖曳家具（床、書桌、衣櫃、沙發、門、窗、鏡子），檢查動線、門口、走道寬度，匯出 PNG 或 PDF。<strong>這是主要工具。</strong></p>
            <a class="button" href="/zh/room-layout-planner/">立即使用</a>
          </article>
        </div>
        <div class="scenario-grid" style="margin-top:var(--space-4)">
          {tools.map((tool) => (
            <article>
              <h3><a href={tool.href}>{tool.title}</a></h3>
              <p>{tool.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="card split-section" aria-labelledby="audience-heading">
        <div>
          <h2 id="audience-heading">適合誰使用</h2>
          <ul>{audiences.map((item) => <li>{item}</li>)}</ul>
        </div>
        <div>
          <h2>可以解決哪些問題</h2>
          <ul>{problems.map((item) => <li>{item}</li>)}</ul>
        </div>
      </section>

      <section class="card" aria-labelledby="feng-heading">
        <h2 id="feng-heading">熱門風水問題</h2>
        <p>以下內容以「民俗上常見說法」與「室內配置舒適度」角度整理，不保證任何結果。請以實際安全、採光、通風、動線與居住需求為優先，並閱讀 <a href="/disclaimer/">免責聲明</a>。</p>
        <ul>{fengShuiQuestions.map((item) => <li><a href={item.href}>{item.title}</a></li>)}</ul>
      </section>

      <section class="card" aria-labelledby="latest-heading">
        <h2 id="latest-heading">最新文章</h2>
        <div class="post-list">
          {latestPosts.map((post) => (
            <article>
              <p class="meta">{formatDate(post.data.updated)} · <a href={`/zh/category/${post.data.category}/`}>{categoryMeta[post.data.category]?.title}</a></p>
              <h3><a href={`/zh/blog/${post.id}/`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="card" aria-labelledby="popular-heading">
        <h2 id="popular-heading">熱門教學</h2>
        <div class="post-list">
          {popularPosts.map((post) => (
            <article>
              <p class="meta"><a href={`/zh/category/${post.data.category}/`}>{categoryMeta[post.data.category]?.title}</a></p>
              <h3><a href={`/zh/blog/${post.id}/`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="card" aria-labelledby="scenarios-heading">
        <h2 id="scenarios-heading">更多房型與生活情境</h2>
        <ul>
          <li><a href="/zh/blog/long-narrow-bedroom-layout/">長型房間怎麼擺？</a></li>
          <li><a href="/zh/blog/no-window-bedroom-layout/">無窗房間怎麼佈置？</a></li>
          <li><a href="/zh/blog/home-office-bedroom-layout/">臥室兼辦公室怎麼規劃？</a></li>
          <li><a href="/zh/blog/first-apartment-room-layout/">第一次租屋房間怎麼規劃？</a></li>
          <li><a href="/zh/blog/tiny-room-layout-under-5-ping/">5 坪以下小房間怎麼佈置？</a></li>
        </ul>
      </section>

      <Faq items={faq} />
      <RelatedLinks links={[
        { href: '/zh/room-layout-planner/', title: '拖拉式房間平面圖工具' },
        { href: '/zh/room-layout-planner/', title: '房間規劃工具' },
        { href: '/zh/feng-shui-bedroom-checker/', title: '臥室風水檢查工具' },
        { href: '/zh/small-bedroom-layout/', title: '小房間配置工具' },
        { href: '/zh/desk-placement-feng-shui/', title: '書桌擺放參考' },
        { href: '/zh/blog/', title: '房間規劃文章' },
      ]} />
    </div>
  </section>
</Layout>

<style>
  .how-it-works {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
    padding: var(--space-3) var(--space-4);
    margin: var(--space-3) 0 var(--space-4);
    background: var(--color-surface-muted, #f7f6f3);
    border-radius: var(--radius-md);
    list-style: none;
    font-size: var(--text-sm);
  }

  .tool-primary {
    margin-bottom: var(--space-4);
  }

  .tool-card-main {
    border: 2px solid var(--color-primary, #2f6f62);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    display: grid;
    gap: var(--space-3);
  }

  .cta-row,
  .post-list,
  .scenario-grid {
    display: grid;
    gap: var(--space-4);
  }

  .scenario-grid article,
  .post-list article {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
  }

  .split-section {
    display: grid;
    gap: var(--space-5);
  }

  .meta {
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  @media (min-width: 760px) {
    .cta-row {
      grid-template-columns: repeat(2, max-content);
    }

    .scenario-grid,
    .post-list,
    .split-section {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
