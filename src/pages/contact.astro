---
import Layout from '../components/Layout.astro';
import Faq from '../components/Faq.astro';
import RelatedLinks from '../components/RelatedLinks.astro';

const title = '聯絡我們｜RoomFeng';
const description = '回報錯誤、提出房間格局規劃需求、隱私問題、授權問題或網站內容建議。';
const faq = [
  { q: '可以請你們幫我看房間風水嗎？', a: '本站不提供個人命理、占卜或結果保證服務。工具與文章只會提供民俗文化與空間舒適度角度的參考提醒。' },
  { q: '回報問題時應提供哪些資訊？', a: '請提供頁面網址、裝置與瀏覽器、你看到的問題、是否能重現，以及不含敏感個資的簡短描述。' },
  { q: '現在有聯絡表單嗎？', a: '沒有。本站維持靜態架構，請使用公開聯絡信箱 btcson66@gmail.com 回報問題或提出建議。' },
];
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: title,
  description,
  url: 'https://roomfeng.win/contact/',
};
---

<Layout title={title} description={description} canonical="/contact/" lang="zh" jsonLd={jsonLd}>
  <section class="section">
    <div class="container page-grid">
      <article class="card">
        <h1>聯絡我們</h1>
        <p class="lead">如果你發現頁面錯誤、內容不清楚、授權資訊需要補充，或希望提出房間格局規劃工具的實用需求，可以寄信到 <a href="mailto:btcson66@gmail.com">btcson66@gmail.com</a>。</p>
        <p>本專案採分階段建置，但目前已提供靜態網站骨架、共用元件、政策頁、部署文件、房間格局規劃工具、中文與英文內容頁、部落格文章與分類頁。因為網站設計目標是給一般使用者使用，我們特別重視簡單、清楚、可驗證的回饋，例如某個按鈕文字不明確、某個政策說明太難懂、某個頁面在手機上閱讀不順，或某個家具尺寸情境很常見但尚未被涵蓋。</p>
        <p>回報技術問題時，請盡量提供頁面網址、使用的瀏覽器與裝置、操作步驟、預期結果與實際結果。若問題和房間資料有關，請只提供必要的示例尺寸，不要傳送完整住址、門牌、租約、身份資料、付款資訊或其他敏感內容。規劃工具預設會把草稿存在瀏覽器 localStorage，不會上傳到伺服器；因此我們通常也無法從伺服器端替使用者找回本機草稿。</p>
        <p>若你要詢問風水內容，請注意本網站只會以民俗文化與空間舒適度參考的方式處理。可以回報某段文字是否過度肯定、是否缺少免責連結、是否容易讓人誤解為結果保證；但本站不提供個人命盤、占卜、住宅吉凶判定或任何關於財富、健康、人際、感情、運氣的承諾。</p>
        <p>若你要詢問授權或素材來源，請參考 license-audit.md。專案會列出第三方套件授權，家具與介面圖示採自製 SVG，不使用來源不明圖示。產品方向可參考 MIT 授權的 fedepaj/arcada-planner，但本站沒有複製其程式碼或素材。</p>
        <p>本站目前不提供後端表單，避免引入資料庫、伺服器處理或不必要的追蹤。若未來改用第三方表單服務，會先確認資料處理方式，並同步更新隱私權政策。</p>
        <h2>English summary</h2>
        <p>Use btcson66@gmail.com to report bugs, content issues, privacy questions, licensing concerns, or practical room-planning needs. Do not send sensitive personal information. The project does not provide fortune-telling or guaranteed feng shui outcomes.</p>
      </article>
      <div class="cta-band">
        <p>回報前可先查看免責聲明，確認風水參考的語氣與限制。</p>
        <a class="button" href="/disclaimer/">查看免責聲明</a>
      </div>
      <Faq items={faq} />
      <RelatedLinks links={[{ href: '/about/', title: '關於本站' }, { href: '/privacy/', title: '隱私權政策' }, { href: '/changelog/', title: '更新紀錄' }]} />
    </div>
  </section>
</Layout>
