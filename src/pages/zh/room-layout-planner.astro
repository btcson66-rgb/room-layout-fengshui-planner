---
import Layout from '../../components/Layout.astro';
import AdSlot from '../../components/AdSlot.astro';
import Faq from '../../components/Faq.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import '../../styles/planner.css';

const title = '房間家具配置工具｜房間平面圖與風水格局參考';
const description = '免費線上房間家具配置工具，可拖曳床、書桌、衣櫃、沙發、門窗與鏡子，檢查尺寸、動線、門口遮擋，並提供民俗風水格局參考。';
const canonical = '/zh/room-layout-planner/';
const alternates = { zh: '/zh/room-layout-planner/', en: '/en/room-layout-planner/' };
const siteUrl = 'https://roomfeng.win';
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: '房間家具配置工具',
    applicationCategory: 'DesignApplication',
    operatingSystem: 'Web browser',
    url: `${siteUrl}${canonical}`,
    description,
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首頁', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: '房間家具配置工具', item: `${siteUrl}${canonical}` },
    ],
  },
];
const faqItems = [
  {
    q: '這個工具會把房間資料上傳到伺服器嗎？',
    a: '不會。房間尺寸與家具草稿預設只儲存在你的瀏覽器 localStorage，匯出 PNG 或 PDF 也在本機完成。',
  },
  {
    q: '風水檢查代表一定會影響運勢嗎？',
    a: '不代表。頁面中的風水內容僅作民俗文化與空間舒適度參考，不保證任何財運、健康、感情或其他結果。',
  },
  {
    q: '可以用手機拖曳家具嗎？',
    a: '可以。工具使用 pointer events，支援滑鼠與觸控操作；手機畫面會把控制列、平面圖與檢查結果直向排列。',
  },
];
const relatedLinks = [
  { href: '/en/room-layout-planner/', title: 'English room layout planner' },
  { href: '/privacy/', title: '隱私權說明' },
  { href: '/disclaimer/', title: '風水與內容免責聲明' },
];
const relatedArticles = [
  { href: '/zh/blog/bedroom-layout-before-buying-furniture/', title: '買家具前的房間規劃' },
  { href: '/zh/blog/door-window-room-layout/', title: '門窗位置與房間配置' },
  { href: '/zh/blog/room-layout-mistakes/', title: '房間配置常見錯誤' },
  { href: '/zh/blog/room-circulation-width-guide/', title: '走道寬度與動線指南' },
  { href: '/zh/blog/long-narrow-bedroom-layout/', title: '長型房間怎麼擺？' },
  { href: '/zh/blog/square-bedroom-layout/', title: '正方形房間配置' },
  { href: '/zh/blog/l-shaped-room-layout/', title: 'L 型房間規劃' },
  { href: '/zh/blog/plug-outlet-room-layout/', title: '插座位置與房間配置' },
  { href: '/zh/blog/floor-plan-before-moving-guide/', title: '搬家前先畫平面圖' },
];
---

<Layout title={title} description={description} canonical={canonical} lang="zh" alternates={alternates} jsonLd={jsonLd}>
  <section class="section">
    <div class="container page-grid">
      <header>
        <h1>房間家具配置工具</h1>
        <p class="lead">
          輸入房間長寬，拖曳家具放入平面圖，確認動線與門口，再匯出 PNG / PDF 或取得規劃建議。
        </p>
        <ol class="step-flow" aria-label="使用步驟">
          <li class="step-flow-item" aria-current="step">
            <span class="step-num">1</span>
            <span class="step-label">輸入房間尺寸</span>
          </li>
          <li class="step-flow-item">
            <span class="step-num">2</span>
            <span class="step-label">拖曳放置家具</span>
          </li>
          <li class="step-flow-item">
            <span class="step-num">3</span>
            <span class="step-label">匯出 / 取得建議</span>
          </li>
        </ol>
      </header>

      <div id="room-planner" data-planner></div>

      <AdSlot id="planner-mid-zh" adSlot="room-layout-planner-zh-mid" />

      <section class="next-steps-panel" aria-labelledby="next-heading">
        <h2 id="next-heading">完成平面圖後 — 下一步</h2>
        <div class="next-steps-grid">
          <article class="next-step-card">
            <div class="next-step-icon" aria-hidden="true">📋</div>
            <h3>取得文字規劃建議</h3>
            <p>用表單填入門窗條件與家具需求，取得配置、動線、收納與風水參考的文字建議。</p>
            <a class="button secondary" href="/zh/blog/bedroom-layout-before-buying-furniture/">閱讀買家具前規劃教學</a>
          </article>
          <article class="next-step-card">
            <div class="next-step-icon" aria-hidden="true">🪄</div>
            <h3>臥室風水格局檢查</h3>
            <p>用 checklist 參考床對門、鏡子對床、床頭靠窗與動線的民俗說法與空間舒適度提醒。</p>
            <a class="button secondary" href="/zh/feng-shui-bedroom-checker/">前往風水檢查工具</a>
          </article>
          <article class="next-step-card">
            <div class="next-step-icon" aria-hidden="true">📐</div>
            <h3>確認家具放得下嗎？</h3>
            <p>不確定床、桌、衣櫃放得進去嗎？閱讀家具尺寸與走道空間的實用建議。</p>
            <a class="button secondary" href="/zh/furniture-fit-checker/">家具尺寸適配檢查</a>
          </article>
        </div>
        <p class="disclaimer-note">風水內容僅作民俗文化與空間舒適度參考，詳見 <a href="/disclaimer/">免責聲明</a>。</p>
      </section>

      <section class="card" aria-labelledby="related-articles-heading">
        <h2 id="related-articles-heading">相關文章</h2>
        <ul>
          {relatedArticles.map((a) => <li><a href={a.href}>{a.title}</a></li>)}
        </ul>
      </section>

      <Faq items={faqItems} />
      <RelatedLinks links={relatedLinks} />
    </div>
  </section>
</Layout>

<style>
  /* ── Step flow indicator ── */
  .step-flow {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: var(--space-3) 0 0;
  }

  .step-flow-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--color-surface-muted, #f7f6f3);
    border-radius: 999px;
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .step-flow-item[aria-current="step"] {
    background: #2f6f62;
    color: #fff;
  }

  .step-num {
    display: grid;
    place-items: center;
    width: 1.6em;
    height: 1.6em;
    border-radius: 50%;
    font-weight: 800;
    font-size: 0.85em;
    background: rgba(0,0,0,.12);
    flex-shrink: 0;
  }

  .step-flow-item[aria-current="step"] .step-num {
    background: rgba(255,255,255,.25);
  }

  /* ── Next steps panel ── */
  .next-steps-panel {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    background: var(--color-surface);
  }

  .next-steps-panel h2 {
    margin-bottom: var(--space-4);
  }

  .next-steps-grid {
    display: grid;
    gap: var(--space-4);
  }

  .next-step-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    display: grid;
    gap: var(--space-2);
  }

  .next-step-icon {
    font-size: 1.75rem;
  }

  .disclaimer-note {
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  @media (min-width: 640px) {
    .next-steps-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<script>
  import { initPlanner } from '../../planner/planner';

  const strings = {
    roomLength: '房間長度',
    roomWidth: '房間寬度',
    unit: '單位',
    palette: '新增家具',
    templatesLabel: '範例格局',
    selectedItem: '已選項目',
    noSelection: '點選平面圖中的家具後，可調整旋轉、寬度、高度或刪除。',
    width: '寬度',
    height: '深度',
    rotation: '角度',
    rotationSliderLabel: '角度滑桿',
    area: '房間面積',
    checksTitle: '結構檢查',
    noWarnings: '目前沒有明顯的尺寸或動線警示。',
    saveStatus: '已儲存草稿',
    confirmClear: '確定要清除目前設計並回到預設格局嗎？',
    itemList: '家具清單',
    disclaimerLink: '查看免責聲明',
    emptyHint: '選擇家具新增，或套用範例格局。',
    units: { cm: '公分', m: '公尺', ft: '英尺' },
    furniture: {
      bed: '床',
      desk: '書桌',
      wardrobe: '衣櫃',
      sofa: '沙發',
      diningTable: '餐桌',
      door: '門',
      window: '窗',
      mirror: '鏡子',
      custom: '自訂',
    },
    customItem: {
      label: '自訂格子',
      namePlaceholder: '名稱（如：電視櫃）',
      addButton: '新增自訂格子',
      editNameLabel: '格子名稱',
    },
    actions: {
      add: '新增',
      rotate90: '旋轉 90°',
      delete: '刪除',
      exportPng: '匯出 PNG',
      exportPdf: '匯出 PDF',
      save: '手動儲存',
      clear: '清除設計',
    },
    templates: {
      studio: '小套房',
      student: '學生房',
      double: '雙人房',
      living: '客廳',
    },
    warnings: {
      bounds: '有家具超出房間邊界，建議調整位置或尺寸。',
      door: '門片開啟範圍可能被家具遮擋，進出動線可再保留一些空間。',
      aisle: '主要走道可能小於約 60 公分，日常通行可能會覺得擁擠。',
    },
    fengShui: {
      sectionTitle: '風水格局參考',
      bedFacingDoor: '民俗上常見說法會提醒床正對門時，可考慮調整床位或用櫃體、布簾減少直衝感；此為空間舒適度參考。',
      mirrorFacingBed: '民俗參考中常提到鏡子正對床可能造成視覺干擾，可考慮改放側邊或降低反射範圍。',
      deskNoSupport: '常見說法會建議書桌背後有牆面或穩定背景，實務上也能減少背後通行帶來的不安定感。',
      doorwayBlocked: '門口動線被擋時，民俗與日常使用都常建議保持出入口清爽，方便進出與視線辨識。',
      headboardNoWall: '床頭未靠牆時，民俗上常見建議是可考慮讓床頭有穩定依靠；此處僅作格局參考。',
      noWarnings: '目前沒有明顯的風水格局參考提醒。內容僅供民俗文化與空間舒適度參考。',
    },
  };

  const target = document.querySelector('[data-planner]');
  if (target instanceof HTMLElement) {
    initPlanner(target, { strings, fengShui: true, storageKey: 'room-layout-planner:zh' });
  }
</script>
