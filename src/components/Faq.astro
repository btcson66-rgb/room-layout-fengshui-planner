---
interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<section aria-labelledby="faq-heading">
  <h2 id="faq-heading">常見問題 / FAQ</h2>
  <div class="faq-list">
    {items.map((item) => (
      <article class="faq-item">
        <h3>{item.q}</h3>
        <p>{item.a}</p>
      </article>
    ))}
  </div>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</section>
