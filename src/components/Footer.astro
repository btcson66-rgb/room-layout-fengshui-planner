---
import { en } from '../i18n/en';
import { zh } from '../i18n/zh';

interface Props {
  lang?: 'zh' | 'en';
}

const { lang = 'zh' } = Astro.props;
const t = lang === 'en' ? en : zh;
const plannerHref = lang === 'en' ? '/en/room-layout-planner/' : '/zh/room-layout-planner/';
const fitCheckerHref = lang === 'en' ? '/en/furniture-fit-checker/' : '/zh/furniture-fit-checker/';
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <ul class="footer-links">
        <li><a href="/about/">{t.footer.about}</a></li>
        <li><a href="/privacy/">{t.footer.privacy}</a></li>
        <li><a href="/terms/">{t.footer.terms}</a></li>
        <li><a href="/contact/">{t.footer.contact}</a></li>
        <li><a href="/disclaimer/">{t.footer.disclaimer}</a></li>
        <li><a href="/changelog/">{t.footer.changelog}</a></li>
        {lang === 'zh' && <li><a href="/zh/blog/">部落格</a></li>}
        <li><a href={plannerHref}>{t.nav.planner}</a></li>
        <li><a href={fitCheckerHref}>{t.nav.fitChecker}</a></li>
      </ul>
      <p>{t.footer.folkDisclaimer} <a href="/disclaimer/">{t.footer.disclaimer}</a></p>
    </div>
    <p>&copy; 2026 RoomFeng. A Btcson Project.</p>
  </div>
</footer>
