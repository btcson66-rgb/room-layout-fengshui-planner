---
import BaseHead from './BaseHead.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  lang?: 'zh' | 'en';
  ogImage?: string;
  ogType?: string;
  alternates?: {
    zh: string;
    en: string;
    xDefault?: string;
  };
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { title, description, canonical, lang = 'zh', ogImage, ogType, alternates, jsonLd } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <BaseHead title={title} description={description} canonical={canonical} lang={lang} ogImage={ogImage} ogType={ogType} alternates={alternates} jsonLd={jsonLd} />
  </head>
  <body>
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
