---
import { en } from '../i18n/en';
import { zh } from '../i18n/zh';

interface Props {
  lang?: 'zh' | 'en';
}

const { lang = 'zh' } = Astro.props;
const t = lang === 'en' ? en : zh;
const homeHref = lang === 'en' ? '/en/' : '/';
const plannerHref = lang === 'en' ? '/en/room-layout-planner/' : '/zh/room-layout-planner/';
const fitCheckerHref = lang === 'en' ? '/en/furniture-fit-checker/' : '/zh/furniture-fit-checker/';
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={homeHref} aria-label="RoomFeng">
      <svg width="36" height="36" viewBox="0 0 36 36" aria-hidden="true" role="img">
        <rect x="4" y="5" width="28" height="26" rx="3" fill="none" stroke="currentColor" stroke-width="2" />
        <rect x="8" y="19" width="11" height="8" rx="1" fill="#2f6f62" />
        <rect x="21" y="9" width="7" height="12" rx="1" fill="#b86b3d" />
        <path d="M8 15h9M22 25h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
      <span>RoomFeng</span>
    </a>
    <nav aria-label="Main navigation">
      <ul class="nav-list">
        <li><a href={homeHref}>{t.nav.home}</a></li>
        <li><a href={plannerHref} style="font-weight:700">{t.nav.planner}</a></li>
        {lang === 'zh' && <li><a href="/zh/feng-shui-bedroom-checker/">風水檢查</a></li>}
        <li><a href={fitCheckerHref}>{t.nav.fitChecker}</a></li>
        {lang === 'zh' && <li><a href="/zh/blog/">部落格</a></li>}
      </ul>
    </nav>
    <div class="language-switcher" aria-label="Language switcher">
      <a href="/" lang="zh">{t.nav.languageZh}</a>
      <a href="/en/" lang="en">{t.nav.languageEn}</a>
    </div>
  </div>
</header>
