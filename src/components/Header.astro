---
import { zh } from '../i18n/zh';
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="RoomFeng 房間規劃與風水佈局工具">
      <svg width="36" height="36" viewBox="0 0 36 36" aria-hidden="true" role="img">
        <rect x="4" y="5" width="28" height="26" rx="3" fill="none" stroke="currentColor" stroke-width="2" />
        <rect x="8" y="19" width="11" height="8" rx="1" fill="#2f6f62" />
        <rect x="21" y="9" width="7" height="12" rx="1" fill="#b86b3d" />
        <path d="M8 15h9M22 25h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
      <span>RoomFeng</span>
    </a>
    <nav aria-label="主要導覽">
      <ul class="nav-list">
        <li><a href="/">{zh.nav.home}</a></li>
        <li><a href="/zh/room-layout-planner/" style="font-weight:700">畫平面圖</a></li>
        <li><a href="/zh/feng-shui-bedroom-checker/">風水檢查</a></li>
        <li><a href="/zh/furniture-fit-checker/">{zh.nav.fitChecker}</a></li>
        <li><a href="/zh/blog/">文章</a></li>
      </ul>
    </nav>
    <div class="language-switcher" aria-label="Language switcher">
      <a href="/" lang="zh">{zh.nav.languageZh}</a>
      <a href="/en/" lang="en">{zh.nav.languageEn}</a>
    </div>
  </div>
</header>
