---
interface RelatedLink {
  href: string;
  title: string;
}

interface Props {
  links: RelatedLink[];
}

const { links } = Astro.props;
---

<nav class="related-links" aria-labelledby="related-heading">
  <h2 id="related-heading">相關頁面 / Related</h2>
  <ul>
    {links.map((link) => <li><a href={link.href}>{link.title}</a></li>)}
  </ul>
</nav>
